{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": false,  // Changed from true to catch type issues
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "typeRoots": [          // Add this to explicitly specify type locations
      "./node_modules/@types",
      "./src/types"
    ],
    "types": ["node"]       // Keep this for global types
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}